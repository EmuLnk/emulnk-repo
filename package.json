{
  "name": "emulnk-repo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "validate": "node scripts/validate.cjs",
    "package": "tsx scripts/package.ts",
    "clean": "tsx scripts/clean.ts",
    "new": "tsx scripts/new.ts",
    "serve": "tsx scripts/dev.ts",
    "mock:init": "tsx scripts/mock-init.ts",
    "validate:profiles": "tsx scripts/validate-profiles.ts",
    "typegen": "tsx scripts/typegen.ts",
    "profile:info": "tsx scripts/profile-info.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "index:gen": "tsx scripts/sync-index.ts",
    "tags": "node -e \"const {ALLOWED_TAGS}=require('./scripts/validate.cjs');console.log([...ALLOWED_TAGS].join(', '))\"",
    "ci": "pnpm build && pnpm typecheck && pnpm validate && pnpm validate:profiles && pnpm typegen && pnpm test && pnpm index:gen --check"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "sharp",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "themes/**/src/**/*.{ts,tsx,svelte}": ["pnpm typecheck"],
    "themes/**/theme.json": ["pnpm validate"],
    "profiles/*.json": ["pnpm validate:profiles"]
  },
  "devDependencies": {
    "@preact/signals-core": "^1.14.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^25.5.0",
    "glob": "^11.0.0",
    "lit": "^3.2.0",
    "sass": "^1.85.0",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0",
    "simple-git-hooks": "^2.11.0",
    "lint-staged": "^15.5.0"
  }
}
