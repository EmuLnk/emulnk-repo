{
  "name": "emulnk-repo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "validate": "node scripts/validate.cjs",
    "package": "tsx scripts/package.ts",
    "clean": "tsx scripts/clean.ts",
    "new": "tsx scripts/new.ts",
    "ci": "pnpm build && pnpm typecheck && pnpm validate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "devDependencies": {
    "@preact/signals-core": "^1.14.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^25.5.0",
    "glob": "^11.0.0",
    "lit": "^3.2.0",
    "sass": "^1.85.0",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
