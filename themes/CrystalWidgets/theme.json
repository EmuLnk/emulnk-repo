{
  "id": "CrystalWidgets",
  "targetProfileId": "PMC",
  "targetConsole": "GBC",
  "type": "overlay",
  "meta": {
    "name": "Crystal Widgets",
    "author": "EmuLnk Team",
    "version": "2.0.0",
    "description": "Minimal type badges for Pokemon Crystal battles. Two tiny widgets you can place next to the HP bars.",
    "minAppVersion": 1
  },
  "hideOverlay": false,
  "widgets": [
    {
      "id": "foe-type",
      "label": "Foe Type",
      "src": "widgets/foe-type.html",
      "defaultWidth": 48,
      "defaultHeight": 60,
      "defaultX": 140,
      "defaultY": 30,
      "resizable": true,
      "transparent": true,
      "minWidth": 36,
      "minHeight": 40
    },
    {
      "id": "you-type",
      "label": "Your Type",
      "src": "widgets/you-type.html",
      "defaultWidth": 48,
      "defaultHeight": 60,
      "defaultX": 140,
      "defaultY": 200,
      "resizable": true,
      "transparent": true,
      "minWidth": 36,
      "minHeight": 40
    }
  ]
}
